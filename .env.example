# Beeclou Configuration

# Google Forms
VITE_GOOGLE_FORM_ID=YOUR_FORM_ID_HERE

# Social & Contact
VITE_INSTAGRAM_URL=https://instagram.com/beeclou
VITE_CONTACT_EMAIL=hello@beeclou.com
VITE_CONTACT_FORM_ID=YOUR_TESTER_FORM_ID_HERE

# Analytics (optionnel)
VITE_GA_ID=
VITE_VERCEL_ANALYTICS_ENABLED=true

# Notes:
# 1. Copier ce fichier en .env.local et remplir les valeurs
# 2. IMPORTANT: Ne pas commiter .env.local sur GitHub
# 3. Les vraies URLs doivent être configurées dans src/main.js
